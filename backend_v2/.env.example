# MindPal Backend V2 环境配置
# 复制此文件为 .env 并填写实际值

# ==================== 基础配置 ====================
# 本文件仅用于本地开发示例，禁止直接用于生产环境。
APP_NAME=MindPal API
APP_VERSION=2.0.0
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
# PostgreSQL（请替换为你自己的本地账号密码）
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/mindpal
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
# 生产环境请用密码认证的 URL: redis://:password@host:6379/0
# 未配置时系统自动降级到进程内 InMemoryCache（单节点够用，多节点会不一致）
REDIS_URL=redis://localhost:6379/0

# ==================== LLM 响应缓存 ====================
# 开启后命中 hash(system_prompt + messages + temperature + model) 可直接回放
# 预计能降 20-30% LLM 调用量（高频问候、常见问题场景）
# 危机模式 / temperature>=0.9 / 极短极长消息 会自动 skip 缓存
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400       # 默认 24 小时

# ==================== 内容审核（P3-2 合规）====================
# 全局开关：false 则完全不做审核（生产环境不要设 false）
MODERATION_ENABLED=true
# dry-run：返回命中信息但不阻断 —— 用于运营上线前调阈值
MODERATION_DRY_RUN=false

# 外部词库路径（优先级高于内置示例）
# 格式参考 services/moderation/filters.py 顶部注释
# 例: MODERATION_WORDLIST_PATH=/etc/mindpal/moderation/wordlist.txt
MODERATION_WORDLIST_PATH=

# 阿里云内容安全（绿网）
# 开通: https://www.aliyun.com/product/lvwang
# SDK:  pip install aliyun-python-sdk-green
MODERATION_ALIYUN_ENABLED=false
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_MODERATION_REGION=cn-shanghai

# Qdrant (向量数据库)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ==================== 安全配置 ====================
# JWT密钥 (生产环境请使用强密钥)
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS允许的源 (JSON数组格式)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5500","http://127.0.0.1:5500"]

# ==================== LLM配置 ====================
# 阿里云通义千问 (DashScope)
# 获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key
QWEN_MODEL=qwen-max

# Anthropic Claude (情感对话)
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-3-sonnet-20240229

# 火山引擎 (备用)
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# ==================== 游戏配置 ====================
DEFAULT_GOLD=1000
DEFAULT_DIAMONDS=0
MAX_INVENTORY_SLOTS=48

# ==================== 配额配置 ====================
FREE_DAILY_CHAT_LIMIT=100
FREE_DAILY_VOICE_LIMIT=10
PREMIUM_DAILY_CHAT_LIMIT=-1
PREMIUM_DAILY_VOICE_LIMIT=-1

# ==================== 支付配置 ====================
# 支付宝
# 沙箱申请:  https://open.alipay.com/develop/sandbox
# 生产申请:  https://open.alipay.com/develop/manage
#
# 启动支付前必须:
#   1. 申请应用拿到 APP_ID
#   2. 生成 RSA2 密钥对, 公钥上传到支付宝, 私钥填到 ALIPAY_PRIVATE_KEY
#   3. 从支付宝后台获取支付宝公钥, 填到 ALIPAY_ALIPAY_PUBLIC_KEY
#   4. 部署 HTTPS 回调 URL (notify_url 和 return_url 必须公网可达)
#   5. 本地开发可用 ngrok / frp 暴露 http://localhost:8000/api/v1/payment/notify/alipay
#   6. 运行 `python -m scripts.seed_products` 创建会员套餐记录
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/alipay
ALIPAY_RETURN_URL=https://your-domain.com/subscription.html
ALIPAY_SANDBOX=true

# 微信支付
# 商户平台:  https://pay.weixin.qq.com/
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_API_V3_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify/wechat
