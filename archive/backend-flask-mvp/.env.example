# MindPal Flask MVP Backend 环境变量示例
# 复制为 .env 后填入本地真实值；不要将真实密钥提交到仓库。
# 本文件仅用于本地开发示例，禁止直接用于生产环境。

# 阿里云配置
DASHSCOPE_API_KEY=your_dashscope_api_key

# 模型配置
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v2

# Flask配置
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-in-local-env

# 数据库配置
DATABASE_URL=sqlite:///data/mindpal.db

# CORS配置
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500

# 文件上传配置
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
